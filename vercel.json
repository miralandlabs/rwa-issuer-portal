{
    "version": 2,
    "name": "rwa-issuer-portal",
    "builds": [
        {
            "src": "src/bin/portal.rs",
            "use": "vercel-rust@4.0.8",
            "config": {
                "env": {
                    "CARGO_HOME": "/tmp/cargo",
                    "RUSTUP_HOME": "/tmp/rustup"
                }
            }
        },
        {
            "src": "public/**/*",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/health",
            "dest": "/src/bin/portal",
            "methods": ["GET", "HEAD", "OPTIONS"]
        },
        {
            "src": "/api/(.*)",
            "dest": "/src/bin/portal",
            "methods": ["GET", "POST", "PATCH", "OPTIONS"]
        },
        {
            "src": "/assets/(.*)",
            "dest": "/public/assets/$1"
        },
        {
            "src": "/(.*\\.(js|css|svg|png|ico|webmanifest|txt))$",
            "dest": "/public/$1"
        },
        {
            "src": "/",
            "dest": "/public/index.html"
        },
        {
            "src": "/(.*)",
            "dest": "/public/index.html"
        }
    ]
}

# rwa-issuer-portal environment template. Copy to .env and fill in.
#
# The portal is RECORDS-ONLY: it never holds a Solana keypair and never writes
# on-chain. A separate ops sync consumes /api/v1/sync/feed and drives the
# rwa-kyc-hook CLI with the ops keypair.

# --- Shared Supabase Postgres (same DB as aethervane / spl-token-balance) ---
DATABASE_URL=postgres://postgres.xxx:password@xxx.supabase.co:5432/postgres?sslmode=require

# --- Portal admin (one bearer token per deployment; gates review / sync) ---
# PORTAL_ADMIN_TOKEN=change-me-long-random
# PORTAL_ADMIN_TOKEN_SHA256=
# Set to 1 only for local dev without an admin token (admin endpoints stay locked).
# PORTAL_ADMIN_TOKEN_OPTIONAL=1

# --- Logging ---
RUST_LOG=rwa_issuer_portal=info
